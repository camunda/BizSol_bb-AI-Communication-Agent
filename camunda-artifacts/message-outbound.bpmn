<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0q9ej5z" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="message-outbound" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Message for customer added to outbox">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=customerContext" target="customerContext" />
          <zeebe:output source="=outboundMessageContext" target="outboundMessageContext" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_11gux22</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="Event_0k57jir" name="Message successfully sent">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=&#34;Message successfully sent&#34;" target="outboundMessageResult" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_00s4rjw</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_11gux22" sourceRef="StartEvent_1" targetRef="Gateway_1gvhp9t" />
    <bpmn:sendTask id="Activity_Reply-to-customer-via-test-channel" name="Reply to customer via email" zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="message-communication-agent-to-customer-email" target="messageName" />
          <zeebe:input source="=customerContext.contactEmail" target="correlationKey" />
          <zeebe:input source="=outboundMessageContext" target="variables" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1aqwghz</bpmn:incoming>
      <bpmn:outgoing>Flow_077r2h1</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="Gateway_1gvhp9t" name="Choose outbound channel" default="Flow_1aqwghz">
      <bpmn:incoming>Flow_11gux22</bpmn:incoming>
      <bpmn:outgoing>Flow_19p83gf</bpmn:outgoing>
      <bpmn:outgoing>Flow_1aqwghz</bpmn:outgoing>
      <bpmn:outgoing>Flow_0hxmooj</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_19p83gf" sourceRef="Gateway_1gvhp9t" targetRef="Activity_0m19nts">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=outboundMessageContext.channel = "chat"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_00yl0om">
      <bpmn:incoming>Flow_1dmybp2</bpmn:incoming>
      <bpmn:incoming>Flow_0w7u2dr</bpmn:incoming>
      <bpmn:incoming>Flow_077r2h1</bpmn:incoming>
      <bpmn:outgoing>Flow_1if08iv</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1if08iv" sourceRef="Gateway_00yl0om" targetRef="Activity_0x6z9wa" />
    <bpmn:sendTask id="Activity_0m19nts" name="Reply to customer via Chat" zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="message-communication-agent-to-customer-chat" target="messageName" />
          <zeebe:input source="=customerContext.contactChat" target="correlationKey" />
          <zeebe:input source="=outboundMessageContext" target="variables" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_19p83gf</bpmn:incoming>
      <bpmn:outgoing>Flow_1dmybp2</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="Flow_1dmybp2" sourceRef="Activity_0m19nts" targetRef="Gateway_00yl0om" />
    <bpmn:sequenceFlow id="Flow_1aqwghz" sourceRef="Gateway_1gvhp9t" targetRef="Activity_Reply-to-customer-via-test-channel" />
    <bpmn:sendTask id="Activity_08zvbke" name="Reply to customer via SMS" zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="message-communication-agent-to-customer-sms" target="messageName" />
          <zeebe:input source="=customerContext.contactSms" target="correlationKey" />
          <zeebe:input source="=outboundMessageContext" target="variables" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0hxmooj</bpmn:incoming>
      <bpmn:outgoing>Flow_0w7u2dr</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="Flow_0hxmooj" sourceRef="Gateway_1gvhp9t" targetRef="Activity_08zvbke">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=outboundMessageContext.channel = "sms"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:subProcess id="Activity_0rgp5xz" triggeredByEvent="true">
      <bpmn:startEvent id="Event_10evmo6" name="Message sending failed">
        <bpmn:outgoing>Flow_1hwhjt2</bpmn:outgoing>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_0zxb2ha" />
      </bpmn:startEvent>
      <bpmn:endEvent id="Event_0gf2wm2" name="Message could not be sent">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="=&#34;Message could not be sent&#34;" target="outboundMessageResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1hwhjt2</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_1hwhjt2" sourceRef="Event_10evmo6" targetRef="Event_0gf2wm2" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_0w7u2dr" sourceRef="Activity_08zvbke" targetRef="Gateway_00yl0om" />
    <bpmn:sequenceFlow id="Flow_077r2h1" sourceRef="Activity_Reply-to-customer-via-test-channel" targetRef="Gateway_00yl0om" />
    <bpmn:sendTask id="Activity_0x6z9wa" name="DEBUG Forward via chat">
      <bpmn:documentation>Use this activity to reply to the customer via chat to ask questions and clarify requirements. Keep it medium-length here. The tool will not directly return a result, but you may have to wait for a reply.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="chat-response" />
        <zeebe:ioMapping>
          <zeebe:input source="=customerContext.contactChat" target="chatHandle" />
          <zeebe:input source="=outboundMessageContext.channel + &#34; / &#34; + outboundMessageContext.subject + &#34; / &#34; + outboundMessageContext.message" target="botResponse" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1if08iv</bpmn:incoming>
      <bpmn:outgoing>Flow_00s4rjw</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="Flow_00s4rjw" sourceRef="Activity_0x6z9wa" targetRef="Event_0k57jir" />
    <bpmn:group id="Group_0scjr2y" categoryValueRef="CategoryValue_0h4vpbs" />
    <bpmn:textAnnotation id="TextAnnotation_1g5aufe">
      <bpmn:text>Replace the outbound channels with your own channels and own connectors, e.g., sending emails via SMTP or SMS via third-party provider APIs.

Implement your own fallback hierarchy, e.g., sending an email in case an SMS could not be sent or the chat was closed --- or leave this to the communication agent to handle.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0qpztj4" associationDirection="None" sourceRef="Group_0scjr2y" targetRef="TextAnnotation_1g5aufe" />
    <bpmn:textAnnotation id="TextAnnotation_0m8gep0">
      <bpmn:text>Use events to implement fallback logic, e.g., send an email if sending a chat message failed.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_02sp20o" associationDirection="None" sourceRef="Activity_0rgp5xz" targetRef="TextAnnotation_0m8gep0" />
  </bpmn:process>
  <bpmn:category id="Category_0y9i5wn">
    <bpmn:categoryValue id="CategoryValue_0h4vpbs" value="Send message to customer" />
  </bpmn:category>
